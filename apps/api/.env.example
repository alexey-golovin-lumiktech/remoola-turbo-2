# ============================================
# Remoola API - Environment Variables
# ============================================

# Application Environment
# node
NODE_ENV="development"
PORT="3333"

# database
DATABASE_URL="DATABASE_URL"
POSTGRES_HOST="POSTGRES_HOST"
POSTGRES_USER="POSTGRES_USER"
POSTGRES_PASSWORD="POSTGRES_PASSWORD"
POSTGRES_DB="POSTGRES_DB"
POSTGRES_PORT="POSTGRES_PORT"
POSTGRES_TIMEZONE="UTC"

# nest
NEST_APP_EXTERNAL_ORIGIN="http://localhost:3333/api"
CONSUMER_APP_ORIGIN="http://localhost:3001"
CONSUMER_MOBILE_APP_ORIGIN="http://localhost:3002"
ADMIN_APP_ORIGIN="http://localhost:3000"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:3010,http://127.0.0.1:3001,http://127.0.0.1:3002,http://localhost:3010,http://localhost:3001,http://localhost:3002,http://localhost:3010,http://localhost:3001,http://localhost:3002"

# google
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="GOOGLE_CLIENT_SECRET"

# jwt — dev: 1d/7d for convenience; production MUST use short-lived (e.g. 15m) per governance
JWT_ACCESS_TOKEN_EXPIRES_IN="1d"
JWT_REFRESH_TOKEN_EXPIRES_IN="168h"
JWT_ACCESS_SECRET="JWT_ACCESS_SECRET"
JWT_REFRESH_SECRET="JWT_REFRESH_SECRET"

# authLockout (envs defaults)
AUTH_MAX_FAILED_ATTEMPTS="5"
AUTH_LOCKOUT_DURATION_MINUTES="15"
AUTH_PER_EMAIL_RATE_LIMIT="50"
AUTH_PER_EMAIL_RATE_WINDOW_MINUTES="15"

# mail
BREVO_API_KEY="BREVO_API_KEY"
BREVO_API_BASE_URL="https://api.brevo.com/v3"
BREVO_DEFAULT_FROM_EMAIL="noreply@wirebill.com"
BREVO_DEFAULT_FROM_NAME="Wirebill"
BREVO_VERIFY_ON_BOOT="false"

# stripe
STRIPE_SECRET_KEY="sk_test_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="STRIPE_WEBHOOK_SECRET"

# aws
AWS_ACCESS_KEY_ID="AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="AWS_SECRET_ACCESS_KEY"
AWS_REGION="AWS_REGION"
AWS_BUCKET="AWS_BUCKET"

# app
SECURE_SESSION_SECRET="SECURE_SESSION_SECRET"
DEFAULT_ADMIN_EMAIL="DEFAULT_ADMIN_EMAIL"
DEFAULT_ADMIN_PASSWORD="DEFAULT_ADMIN_PASSWORD"
SUPER_ADMIN_EMAIL="SUPER_ADMIN_EMAIL"
SUPER_ADMIN_PASSWORD="SUPER_ADMIN_PASSWORD"
ALLOW_PRODUCTION_BOOTSTRAP_SEED="false"

# ngrok
NGROK_AUTH_TOKEN="NGROK_AUTH_TOKEN"
NGROK_DOMAIN="NGROK_DOMAIN"

# vercel
VERCEL="0"

# security
COOKIE_SECURE="false"

# common (envs defaults; override if needed)
EXCHANGE_RATE_MAX_AGE_HOURS="24"
CONSUMER_DEVICE_ID_ALLOW_UNSIGNED_FALLBACK="false"
CONSUMER_ACTION_LOG_RETENTION_DAYS="30"
CONSUMER_ACTION_LOG_PARTITION_PRECREATE_MONTHS="2"
CONSUMER_ACTION_LOG_MAINTENANCE_CRON="17 */6 * * *"
CONSUMER_ACTION_LOG_RETENTION_CRON="23 3 * * *"
CONSUMER_ACTION_LOG_BACKPRESSURE_ENABLED="true"
CONSUMER_ACTION_LOG_LOW_PRIORITY_MAX_PER_SECOND="250"
CONSUMER_ACTION_LOG_OVERFLOW_SAMPLE_RATE="0.1"
CONSUMER_ACTION_LOG_BACKPRESSURE_SUMMARY_INTERVAL_SECONDS="60"
CONSUMER_ACTION_LOG_BACKPRESSURE_SUMMARY_MIN_DROPPED="10"
CONSUMER_ACTION_LOG_CALLBACK_FAILURE_RATE_LIMIT_ENABLED="true"
CONSUMER_ACTION_LOG_CALLBACK_FAILURE_MAX_PER_WINDOW="30"
CONSUMER_ACTION_LOG_CALLBACK_FAILURE_WINDOW_SECONDS="60"
CONSUMER_ACTION_LOG_STORE_IP_ADDRESS="false"
CONSUMER_ACTION_LOG_STORE_USER_AGENT="false"
CONSUMER_OAUTH_ALLOW_MISSING_STATE_COOKIE_FALLBACK="false"

# Development & Monitoring
TURBO_TELEMETRY_DISABLED="1"
DO_NOT_TRACK="1"
