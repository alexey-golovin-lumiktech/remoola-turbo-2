{
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/jobs/stripe-reversal-notification-outbox",
      "schedule": "0 0 * * *"
    }
  ]
}
