# ============================================
# Remoola Admin App - Environment Variables
# ============================================

# Application Environment
NODE_ENV="development"

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333/api

# Vercel Deployment (set to 1 when deploying to Vercel)
VERCEL="0"

# security
COOKIE_SECURE="true"

# JWT cookie TTLs (seconds) — must match API JWT_ACCESS_TOKEN_EXPIRES_IN / JWT_REFRESH_TOKEN_EXPIRES_IN
JWT_ACCESS_EXPIRES_SECONDS="900"
JWT_REFRESH_EXPIRES_SECONDS="604800"

# Development & Monitoring
TURBO_TELEMETRY_DISABLED="1"
DO_NOT_TRACK="1"
