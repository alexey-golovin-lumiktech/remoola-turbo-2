{
  "name": "@remoola/admin-v2",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3011",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "TERM=dumb NO_COLOR=1 node ../../scripts/ensure-local-development.js admin-v2:test && node ../../scripts/run-jest-with-memory-cap.js",
    "test:watch": "TERM=dumb NO_COLOR=1 node ../../scripts/ensure-local-development.js admin-v2:test:watch && node ../../scripts/run-jest-with-memory-cap.js --watch",
    "clean": "rm -rf ./node_modules ./.next"
  },
  "dependencies": {
    "@remoola/api-types": "^0.0.0",
    "@remoola/ui": "^0.0.0",
    "next": "15.5.7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@remoola/eslint-config": "^0.0.0",
    "@remoola/jest-config": "^0.0.0",
    "@remoola/typescript-config": "^0.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "eslint": "^9.31.0",
    "eslint-config-next": "15.5.2",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.8.2",
    "typescript-plugin-css-modules": "^5.2.0"
  }
}
