# ============================================
# Remoola Admin v2 App - Environment Variables
# ============================================

# Application Environment
NODE_ENV="development"

# API Configuration
# Keep this aligned with the frontend host strategy:
# - supported: localhost frontend + localhost api
# - supported: 127.0.0.1 frontend + 127.0.0.1 api
# - unsupported: mixed localhost/127.0.0.1 flows because cookies use different jars
NEXT_PUBLIC_API_BASE_URL="http://localhost:3334/api"
# Canonical frontend origin used by same-origin BFF/auth flows.
# This must be set explicitly in every environment; there is no implicit localhost fallback.
# `NEXT_PUBLIC_APP_ORIGIN` remains legacy fallback only and is not the primary release contract.
ADMIN_V2_APP_ORIGIN="http://localhost:3011"

# Stripe Configuration (for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"

# Vercel Deployment (set to 1 when deploying to Vercel)
VERCEL="0"

# security
# Consumer session cookies are frontend-domain cookies issued via Next BFF routes.
# For real HTTPS production traffic this must be true.
COOKIE_SECURE="true"

# Development & Monitoring
TURBO_TELEMETRY_DISABLED="1"
DO_NOT_TRACK="1"
