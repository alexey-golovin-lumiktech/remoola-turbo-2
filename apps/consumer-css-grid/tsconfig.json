{
  "extends": "@remoola/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      { "name": "next" },
      { "name": "typescript-plugin-css-modules" }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/test/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
