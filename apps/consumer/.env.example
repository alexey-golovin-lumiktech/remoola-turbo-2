# ============================================
# Remoola Consumer App - Environment Variables
# ============================================

# Application Environment
NODE_ENV="development"

# API Configuration
NEXT_PUBLIC_API_BASE_URL="http://localhost:3333/api"
# Canonical frontend origin used by same-origin BFF/auth flows in production.
# `NEXT_PUBLIC_APP_ORIGIN` remains legacy fallback only and is not the primary release contract.
CONSUMER_APP_ORIGIN="http://localhost:3001"
# Optional production cutover target for legacy web redirects to consumer-css-grid.
CONSUMER_CSS_GRID_APP_ORIGIN="http://localhost:3003"

# Stripe Configuration (for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"

# Vercel Deployment (set to 1 when deploying to Vercel)
VERCEL="0"

# security
COOKIE_SECURE="true"

# Development & Monitoring
TURBO_TELEMETRY_DISABLED="1"
DO_NOT_TRACK="1"
