{
  "name": "remoola-turbo-2",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @remoola/database-2 run db:generate && turbo run build",
    "build:vercel-guard": "turbo run build --filter=@remoola/api --filter=@remoola/api-v2 --filter=@remoola/consumer --filter=@remoola/consumer-css-grid --filter=@remoola/admin --filter=@remoola/consumer-mobile",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "yarn workspace @remoola/database-2 run db:generate",
    "db:validate": "yarn workspace @remoola/database-2 run db:validate",
    "db:deploy": "yarn workspace @remoola/database-2 run db:deploy",
    "db:studio": "yarn workspace @remoola/database-2 run db:studio",
    "db:migrate": "yarn workspace @remoola/database-2 run db:migrate",
    "db:migrate:skip:generate": "yarn workspace @remoola/database-2 run db:migrate:skip:generate",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "schema:generate:helpers": "node ./packages/api-types/scripts/generate-schema-helpers.js",
    "schema:check": "yarn workspace @remoola/database-2 run db:generate && yarn workspace @remoola/database-2 run db:validate && yarn workspace @remoola/api-types run build && yarn workspace @remoola/api-types run typecheck && yarn workspace @remoola/api run typecheck && yarn workspace @remoola/admin run typecheck",
    "postinstall": "turbo run build --filter=\"./packages/*\" --filter=\"!@remoola/db-fixtures\" --filter=\"!@remoola/test-db\" --filter=\"!@remoola/api-e2e\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:v2-apps": "yarn workspace @remoola/consumer-css-grid run typecheck && yarn workspace @remoola/api-v2 run typecheck",
    "typecheck:watch": "turbo run typecheck:watch --parallel",
    "test": "TERM=dumb NO_COLOR=1 node ./scripts/ensure-local-development.js root:test && turbo run test",
    "test-db:cleanup": "TERM=dumb NO_COLOR=1 node ./scripts/cleanup-stale-test-dbs.js",
    "test:e2e": "TERM=dumb NO_COLOR=1 node ./scripts/ensure-local-development.js root:test:e2e && node ./scripts/cleanup-stale-test-dbs.js && turbo run test:e2e",
    "test:e2e:fast": "TERM=dumb NO_COLOR=1 node ./scripts/ensure-local-development.js root:test:e2e:fast && node ./scripts/cleanup-stale-test-dbs.js && turbo run test:e2e:fast",
    "test:v2-apps": "yarn workspace @remoola/consumer-css-grid run test && yarn workspace @remoola/api-v2 run test && yarn workspace @remoola/api-v2 run test:e2e",
    "verify:v2-apps": "yarn build:vercel-guard && yarn typecheck:v2-apps && yarn test:v2-apps",
    "dev:api": "yarn workspace @remoola/api run dev",
    "lint:api": "yarn workspace @remoola/api run lint",
    "lint:fix:api": "yarn workspace @remoola/api run lint --fix",
    "dev:consumer": "yarn workspace @remoola/consumer run dev",
    "lint:consumer": "yarn workspace @remoola/consumer run lint",
    "lint:fix:consumer": "yarn workspace @remoola/consumer run lint --fix",
    "dev:admin": "yarn workspace @remoola/admin run dev",
    "lint:admin": "yarn workspace @remoola/admin run lint",
    "lint:fix:admin": "yarn workspace @remoola/admin run lint --fix",
    "dev:consumer-mobile": "yarn workspace @remoola/consumer-mobile run dev",
    "lint:consumer-mobile": "yarn workspace @remoola/consumer-mobile run lint",
    "lint:fix:consumer-mobile": "yarn workspace @remoola/consumer-mobile run lint --fix",
    "dev:consumer-css-grid": "yarn workspace @remoola/consumer-css-grid run dev",
    "lint:consumer-css-grid": "yarn workspace @remoola/consumer-css-grid run lint",
    "lint:fix:consumer-css-grid": "yarn workspace @remoola/consumer-css-grid run lint --fix",
    "dev:api-v2": "yarn workspace @remoola/api-v2 run dev",
    "lint:api-v2": "yarn workspace @remoola/api-v2 run lint",
    "lint:fix:api-v2": "yarn workspace @remoola/api-v2 run lint --fix",
    "turbo:dev:api": "turbo run dev --filter=@remoola/api",
    "turbo:dev:consumer": "turbo run dev --filter=@remoola/consumer",
    "turbo:dev:admin": "turbo run dev --filter=@remoola/admin",
    "turbo:dev:consumer-mobile": "turbo run dev --filter=@remoola/consumer-mobile",
    "lint:fix:apps": "yarn lint:fix:api && yarn lint:fix:api-v2 && yarn lint:fix:consumer && yarn lint:fix:admin && yarn lint:fix:consumer-mobile && yarn lint:fix:consumer-css-grid",
    "lint:fix:v2-apps": "yarn lint:fix:api-v2 && yarn lint:fix:consumer-css-grid"
  },
  "dependencies": {},
  "devDependencies": {
    "@remoola/eslint-config": "^0.0.0",
    "@remoola/typescript-config": "^0.0.0",
    "prettier": "^3.2.5",
    "prisma": "6.19.0",
    "turbo": "^2.5.0"
  },
  "resolutions": {
    "prisma": "6.19.0",
    "@prisma/client": "6.19.0"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  }
}
