{
  "cSpell.words": [],
  "sqltools.connections": [
    {
      "previewLimit": 50,
      "server": "127.0.0.1",
      "port": 5432,
      "driver": "PostgreSQL",
      "name": "remoola",
      "database": "remoola",
      "username": "remoola",
      "password": "remoola"
    }
  ],
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.preferences.importModuleSpecifierEnding": "auto",
  // 🧩 --- ESLint Integration ---
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "pattern": "apps/*"
    },
    {
      "pattern": "packages/*"
    }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.run": "onType",
  // 💾 --- Auto Fix + Formatting ---
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.fixAll.eslint": "always"
  },
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  // 🎨 --- Prettier/Formatting Sync ---
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  // ⚙️ --- Editor Consistency ---
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.wordWrap": "on",
  "editor.quickSuggestions": {
    "strings": true
  },
  // 🚀 --- Workspace Optimization (Enhanced for File Watcher) ---
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/out": true,
    "**/build": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/.cache": true,
    "**/tmp": true,
    "**/temp": true
  },
  "files.exclude": {
    "**/.turbo": true,
    "**/.DS_Store": true
  },
  // 🔍 --- File Watcher Exclusions (Reduces inotify load) ---
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/coverage/**": true,
    "**/test-results/**": true,
    "**/playwright-report/**": true,
    "**/.cache/**": true,
    "**/tmp/**": true,
    "**/temp/**": true,
    "**/*.log": true,
    "**/logs/**": true,
    "**/.yarn/cache/**": true,
    "**/.pnp/**": true,
    "**/.eslintcache": true,
    "**/uploads/**": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "change-case.default": [
    "snake_case",
    "camelCase",
    "PascalCase",
    "param-case",
    "CONST_CASE"
  ],
  "change-case.js": [
    "snake_case",
    "camelCase",
    "PascalCase",
    "param-case",
    "CONST_CASE"
  ],
  "change-case.ts": [
    "snake_case",
    "camelCase",
    "PascalCase",
    "param-case",
    "CONST_CASE"
  ],
  "change-case.cs": [
    "snake_case",
    "camelCase",
    "PascalCase",
    "param-case",
    "CONST_CASE"
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.tabs.focusMode": "singleClick",
  "editor.minimap.enabled": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "[snippets]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  }
}
