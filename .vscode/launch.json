{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "API v2: Debug server",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/api-v2",
        "run",
        "start:debug"
      ],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "API v2: Debug current src spec",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/api-v2",
        "run",
        "test:debug",
        "--",
        "--config",
        "jest.config.ts",
        "--runTestsByPath",
        "${file}"
      ],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "API v2: Debug current e2e spec",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/api-v2",
        "run",
        "test:debug",
        "--",
        "--config",
        "../../packages/api-e2e/jest-e2e.api-v2.json",
        "--runTestsByPath",
        "${file}"
      ],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Admin v2: Dev server",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/admin-v2",
        "run",
        "dev"
      ],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Admin v2: Debug current test",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/admin-v2",
        "run",
        "test",
        "--",
        "--config",
        "jest.config.ts",
        "--runTestsByPath",
        "${file}"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect-brk"
      },
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Consumer CSS Grid: Dev server",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/consumer-css-grid",
        "run",
        "dev"
      ],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Consumer CSS Grid: Debug current test",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "workspace",
        "@remoola/consumer-css-grid",
        "run",
        "test",
        "--",
        "--config",
        "jest.config.ts",
        "--runTestsByPath",
        "${file}"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect-brk"
      },
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}