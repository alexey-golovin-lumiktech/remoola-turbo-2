{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "globalEnv": [
    "ADMIN_APP_ORIGIN",
    "ALLOW_PRODUCTION_BOOTSTRAP_SEED",
    "AWS_ACCESS_KEY_ID",
    "AWS_BUCKET",
    "AWS_REGION",
    "AWS_SECRET_ACCESS_KEY",
    "BREVO_API_BASE_URL",
    "BREVO_API_KEY",
    "BREVO_DEFAULT_FROM_EMAIL",
    "BREVO_DEFAULT_FROM_NAME",
    "BREVO_VERIFY_ON_BOOT",
    "COOKIE_SECURE",
    "CONSUMER_CSS_GRID_APP_ORIGIN",
    "DATABASE_URL",
    "DEFAULT_ADMIN_EMAIL",
    "DEFAULT_ADMIN_PASSWORD",
    "DEV_LOGIN_EMAIL",
    "DEV_LOGIN_PASSWORD",
    "DO_NOT_TRACK",
    "EXCHANGE_RATE_MAX_AGE_HOURS",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_API_KEY",
    "JWT_ACCESS_EXPIRES_SECONDS",
    "JWT_ACCESS_SECRET",
    "JWT_ACCESS_TTL",
    "JWT_EXPIRES_IN",
    "JWT_REFRESH_EXPIRES_SECONDS",
    "JWT_REFRESH_SECRET",
    "JWT_REFRESH_TTL",
    "NEST_APP_EXTERNAL_ORIGIN",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_APP_ORIGIN",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NGROK_AUTH_TOKEN",
    "NGROK_DOMAIN",
    "NODE_ENV",
    "NO_COLOR",
    "OPENAI_API_KEY",
    "PORT",
    "POSTGRES_DB",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_PORT",
    "POSTGRES_SSL",
    "POSTGRES_TIMEZONE",
    "POSTGRES_USER",
    "REDIS_URL",
    "S3_BUCKET",
    "S3_PUBLIC_BASE",
    "SECURE_SESSION_SECRET",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "SUPER_ADMIN_EMAIL",
    "SUPER_ADMIN_PASSWORD",
    "TURBO_TELEMETRY_DISABLED",
    "TEST_DB_PROVIDER",
    "TEST_DB_FAST_REUSE",
    "TEST_DB_JANITOR_POLL_MS",
    "TEST_DB_TTL_MINUTES",
    "TEST_DB_VERBOSE",
    "TEST_DATABASE_URL",
    "VERCEL",
    "VERCEL_AUTOMATION_BYPASS_SECRET",
    "VERCEL_ENV",
    "AUTH_PER_EMAIL_RATE_WINDOW_MINUTES",
    "CONSUMER_ACTION_LOG_RETENTION_DAYS",
    "CONSUMER_ACTION_LOG_PARTITION_PRECREATE_MONTHS",
    "CONSUMER_ACTION_LOG_MAINTENANCE_CRON",
    "CONSUMER_ACTION_LOG_RETENTION_CRON",
    "CONSUMER_ACTION_LOG_BACKPRESSURE_ENABLED",
    "CONSUMER_ACTION_LOG_LOW_PRIORITY_MAX_PER_SECOND",
    "CONSUMER_ACTION_LOG_OVERFLOW_SAMPLE_RATE",
    "CONSUMER_ACTION_LOG_BACKPRESSURE_SUMMARY_INTERVAL_SECONDS",
    "CONSUMER_ACTION_LOG_BACKPRESSURE_SUMMARY_MIN_DROPPED",
    "CONSUMER_ACTION_LOG_CALLBACK_FAILURE_RATE_LIMIT_ENABLED",
    "CONSUMER_ACTION_LOG_CALLBACK_FAILURE_MAX_PER_WINDOW",
    "CONSUMER_ACTION_LOG_CALLBACK_FAILURE_WINDOW_SECONDS",
    "CONSUMER_ACTION_LOG_STORE_IP_ADDRESS",
    "CONSUMER_ACTION_LOG_STORE_USER_AGENT",
    "JWT_ACCESS_TOKEN_EXPIRES_IN",
    "JWT_REFRESH_TOKEN_EXPIRES_IN",
    "AUTH_MAX_FAILED_ATTEMPTS",
    "AUTH_LOCKOUT_DURATION_MINUTES",
    "AUTH_PER_EMAIL_RATE_LIMIT",
    "STRIPE_WEBHOOK_SECRET_BILLING",
    "ADMIN_V2_APP_ORIGIN"
  ],
  "ui": "stream",
  "globalDependencies": ["package.json", "yarn.lock", ".env", ".env.*"],
  "tasks": {
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["DATABASE_URL", "NEXT_PUBLIC_APP_ORIGIN"]
    },
    "lint": {
      "inputs": ["src/**", "test/**", "tests/**", "eslint.config.*", ".eslintrc*", "tsconfig*.json", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "typecheck:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "__tests__/**",
        "jest.config.*",
        "jest.setup.*",
        "tsconfig*.json",
        "package.json"
      ]
    },
    "clean": {
      "cache": false
    },
    "test:e2e": {
      "inputs": ["src/**", "test/**", "tests/**", "jest-e2e*.json", "jest.config.*", "tsconfig*.json", "package.json"]
    },
    "test:e2e:fast": {
      "inputs": ["src/**", "test/**", "tests/**", "jest-e2e*.json", "jest.config.*", "tsconfig*.json", "package.json"]
    },
    "db:generate": {
      "outputs": ["generated/**"],
      "cache": false
    }
  }
}
