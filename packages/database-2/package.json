{
  "name": "@remoola/database-2",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist/**"
  ],
  "scripts": {
    "build": "yarn db:generate && tsc -p tsconfig.build.json",
    "clean": "rm -rf ./node_modules ./dist ./generated/**",
    "postinstall": "npx prisma generate --no-hints",
    "db:generate": "npx prisma generate --no-hints",
    "db:validate": "npx prisma validate --schema prisma/schema.prisma",
    "db:deploy": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:skip:generate": "npx prisma migrate dev --skip-generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "prisma": "6.19.0"
  }
}
