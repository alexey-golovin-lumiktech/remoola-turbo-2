{
  "name": "@remoola/api-types",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "yarn build --watch",
    "schema:generate": "node ./scripts/generate-schema-helpers.js",
    "build": "yarn schema:generate && tsc -b",
    "typecheck": "yarn schema:generate && tsc --noEmit",
    "typecheck:watch": "yarn schema:generate && tsc --noEmit --watch --preserveWatchOutput",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "clean": "rm -rf ./node_modules ./dist"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "dependencies": {
    "@remoola/database-2": "^0.0.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@remoola/eslint-config": "^0.0.0",
    "@remoola/jest-config": "^0.0.0",
    "@remoola/typescript-config": "^0.0.0",
    "@types/node": "^24.3.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "typescript": "5.8.2"
  }
}